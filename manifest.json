{
  "manifest_version": 3,
  "name": "TaskOrbit",
  "version": "1.0.0",
  "description": "Build and run configurable automation workflows (click, select, type text) on the sites you choose.",
  "permissions": ["storage", "scripting", "tabs", "activeTab", "downloads", "alarms", "contextMenus"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TaskOrbit"
  },
  "web_accessible_resources": [{
    "resources": ["content/interceptor.js", "sandbox.html", "sandbox.js"],
    "matches": ["<all_urls>"]
  }],
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/toast.js", "content/autoReveal.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html"
}
