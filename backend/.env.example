# TaskOrbit Backend Configuration

# Server Port
PORT=3000

# JSON Web Token Secret - Keep this secure and private!
# Generate using: openssl rand -base64 32
JWT_SECRET=your_jwt_signing_secret_here

# Admin Authorization Key - required for /v1/admin/* endpoints
# Send as 'X-Admin-Secret' header
ADMIN_SECRET=your_admin_secret_header_key_here

# SQLite Database File Path
DB_PATH=/data/licenses.db
